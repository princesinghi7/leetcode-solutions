class Solution {
public:
    bool canPartitionGrid(vector<vector<int>>& grid) {
        int m = grid.size(), n = grid[0].size();
        
        long long total = 0;
        
        // Step 1: Compute total sum
        for (auto &row : grid) {
            for (int val : row) {
                total += val;
            }
        }
        
        // Step 2: If odd → not possible
        if (total % 2 != 0) return false;
        
        long long target = total / 2;
        
        // Step 3: Check horizontal cuts
        long long sum = 0;
        for (int i = 0; i < m - 1; i++) {
            for (int j = 0; j < n; j++) {
                sum += grid[i][j];
            }
            if (sum == target) return true;
        }
        
        // Step 4: Check vertical cuts
        sum = 0;
        for (int j = 0; j < n - 1; j++) {
            for (int i = 0; i < m; i++) {
                sum += grid[i][j];
            }
            if (sum == target) return true;
        }
        
        return false;
    }
};
