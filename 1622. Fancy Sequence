class Fancy {
public:
    long long mod = 1000000007;
    vector<long long> v;
    long long mul = 1;
    long long add = 0;

    long long power(long long a,long long b){
        long long res=1;
        while(b){
            if(b&1) res=(res*a)%mod;
            a=(a*a)%mod;
            b>>=1;
        }
        return res;
    }

    long long inv(long long x){
        return power(x,mod-2);
    }

    Fancy() {}

    void append(int val) {
        long long x = (val - add + mod) % mod;
        x = (x * inv(mul)) % mod;
        v.push_back(x);
    }

    void addAll(int inc) {
        add = (add + inc) % mod;
    }

    void multAll(int m) {
        mul = (mul * m) % mod;
        add = (add * m) % mod;
    }

    int getIndex(int idx) {
        if(idx >= v.size()) return -1;
        return (v[idx] * mul % mod + add) % mod;
    }
};
