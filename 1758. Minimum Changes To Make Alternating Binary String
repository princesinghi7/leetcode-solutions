class Solution {
public:
    int minOperations(string s) {
        int n = s.length();
        int count1 = 0, count2 = 0;

        for(int i = 0; i < n; i++) {

            // pattern starting with '0'
            char expected1 = (i % 2 == 0) ? '0' : '1';
            if(s[i] != expected1)
                count1++;

            // pattern starting with '1'
            char expected2 = (i % 2 == 0) ? '1' : '0';
            if(s[i] != expected2)
                count2++;
        }

        return min(count1, count2);
    }
};
