class Solution {
public:
    int dist(int a, int b) {
        if (a == -1) return 0;
        int x1 = a / 6, y1 = a % 6;
        int x2 = b / 6, y2 = b % 6;
        return abs(x1 - x2) + abs(y1 - y2);
    }

    int minimumDistance(string word) {
        int n = word.size();
        
        vector<int> dp(26, 0); 
        int total = 0, saved = 0;

        for (int i = 1; i < n; i++) {
            int cur = word[i] - 'A';
            int prev = word[i - 1] - 'A';

            int d = dist(prev, cur);
            total += d;

            vector<int> new_dp(26, 0);

            for (int j = 0; j < 26; j++) {
               
                new_dp[j] = max(new_dp[j], dp[j]);

               
                int gain = d - dist(j, cur);
                new_dp[prev] = max(new_dp[prev], dp[j] + gain);

                saved = max(saved, new_dp[prev]);
            }

            dp = new_dp;
        }

        return total - saved;
    }
};
