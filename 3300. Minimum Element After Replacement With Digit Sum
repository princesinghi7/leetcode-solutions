class Solution {
    public int minElement(int[] nums) {
        int min = Integer.MAX_VALUE;

        for(int num : nums){
            int sum = 0;
            String s = String.valueOf(num);
            for(char c : s.toCharArray()){
                sum += c - '0';
            }
            min = Math.min(min, sum);
        }
        return min;
    }
}
