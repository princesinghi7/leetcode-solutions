class Solution {
public:
    vector<vector<int>> constructProductMatrix(vector<vector<int>>& grid) {
        int n = grid.size();
        int m = grid[0].size();
        int mod = 12345;

        int size = n * m;
        vector<int> flat(size);

        // Step 1: Flatten
        int k = 0;
        for(int i = 0; i < n; i++) {
            for(int j = 0; j < m; j++) {
                flat[k++] = grid[i][j] % mod;
            }
        }

        // Step 2: Prefix
        vector<int> prefix(size, 1);
        for(int i = 1; i < size; i++) {
            prefix[i] = (prefix[i - 1] * flat[i - 1]) % mod;
        }

        // Step 3: Suffix
        vector<int> suffix(size, 1);
        for(int i = size - 2; i >= 0; i--) {
            suffix[i] = (suffix[i + 1] * flat[i + 1]) % mod;
        }

        // Step 4: Answer
        vector<vector<int>> result(n, vector<int>(m));
        k = 0;

        for(int i = 0; i < n; i++) {
            for(int j = 0; j < m; j++) {
                result[i][j] = (prefix[k] * suffix[k]) % mod;
                k++;
            }
        }

        return result;
    }
};
