class Solution {
public:
    int maxPathScore(vector<vector<int>>& grid, int k) {
        int m = grid.size();
        int n = grid[0].size();

        vector<vector<vector<int>>> dp(
            m, vector<vector<int>>(n, vector<int>(k + 1, -1))
        );

        dp[0][0][0] = 0;

        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {

                if (i == 0 && j == 0) continue;

                int val = grid[i][j];
                int cost = (val == 0 ? 0 : 1);

                for (int c = cost; c <= k; c++) {
                    int prevCost = c - cost;
                    int best = -1;

                    if (i > 0 && dp[i - 1][j][prevCost] != -1) {
                        best = max(best, dp[i - 1][j][prevCost] + val);
                    }

                    if (j > 0 && dp[i][j - 1][prevCost] != -1) {
                        best = max(best, dp[i][j - 1][prevCost] + val);
                    }

                    dp[i][j][c] = best;
                }
            }
        }

        int ans = -1;
        for (int c = 0; c <= k; c++) {
            ans = max(ans, dp[m - 1][n - 1][c]);
        }

        return ans;
    }
};
